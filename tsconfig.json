{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./docs/.vitepress/*"]
    }
  },
  "vueCompilerOptions": {
    "vitePressExtensions": [".md"]
  },
  "include": [
    "**/*.md",
    "**/.vitepress/**/*.ts",
    "**/.vitepress/**/*.mts"
  ]
}
